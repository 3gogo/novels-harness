# Copy this file to .env.local in the project root and fill in your values.

OPENAI_API_KEY=your-api-key

# Optional. Leave empty when calling the official OpenAI endpoint directly.
OPENAI_BASE_URL=

# Optional. Defaults to gpt-5-mini when omitted.
OPENAI_MODEL=gpt-5-mini

# Optional. Supported values: minimal, low, medium, high
OPENAI_REASONING_EFFORT=medium
